{
  "AllowedHosts": "*",

  "Database": {
    "Provider": "Sqlite"
  },

  "ConnectionStrings": {
    "Default": "Data Source=crm.db;Cache=Shared"
  },

  "Jwt": {
    "Issuer": "crm.local",
    "Audience": "crm.client",
    "SigningKey": "REPLACE_WITH_AT_LEAST_32_BYTE_SECRET_FROM_USER_SECRETS_OR_KEYVAULT",
    "AccessTokenMinutes": 60,
    "ClockSkewSeconds": 30
  },

  "Cors": {
    "AllowedOrigins": [ "http://localhost:4200", "https://localhost:4200" ]
  },

  "Admin": {
    "SeedPassword": "ChangeMe!123"
  },

  "IpRateLimiting": {
    "EnableEndpointRateLimiting": true,
    "StackBlockedRequests": false,
    "RealIpHeader": "X-Real-IP",
    "ClientIdHeader": "X-ClientId",
    "HttpStatusCode": 429,
    "GeneralRules": [
      { "Endpoint": "*:/api/auth/login", "Period": "1m", "Limit": 10 },
      { "Endpoint": "*:/api/auth/signup", "Period": "1m", "Limit": 5 },
      { "Endpoint": "*", "Period": "1m", "Limit": 200 }
    ]
  },

  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning",
        "System": "Warning"
      }
    },
    "Enrich": [ "FromLogContext", "WithMachineName", "WithProcessId", "WithThreadId" ],
    "WriteTo": [
      { "Name": "Console" },
      {
        "Name": "File",
        "Args": {
          "path": "logs/crm-.log",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 14,
          "outputTemplate": "{Timestamp:yyyy-MM-dd HH:mm:ss.fff zzz} [{Level:u3}] [{CorrelationId}] {Message:lj} {Properties:j}{NewLine}{Exception}"
        }
      }
    ]
  }
}
